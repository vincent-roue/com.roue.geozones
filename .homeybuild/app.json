{
  "id": "com.roue.geozones",
  "version": "1.0.0",
  "sdk": 3,
  "compatibility": ">=5.0.0",
  "platforms": [
    "local"
  ],
  "brandColor": "#2F6FED",
  "name": {
    "en": "GeoZones",
    "fr": "GeoZones",
    "nl": "GeoZones",
    "de": "GeoZones"
  },
  "description": {
    "en": "Create zones on a map and trigger Homey flows based on where a person or device is.",
    "fr": "Créez des zones sur une carte et déclenchez des flows Homey selon l’endroit où se trouve une personne ou un appareil.",
    "nl": "Maak zones op een kaart en start Homey-flows op basis van waar een persoon of apparaat zich bevindt.",
    "de": "Erstelle Zonen auf einer Karte und starte Homey-Flows basierend darauf, wo sich eine Person oder ein Gerät befindet."
  },
  "category": [
    "tools"
  ],
  "author": {
    "name": "Vincent Roué"
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "api": {
    "evaluate": {
      "method": "POST",
      "path": "/evaluate"
    },
    "testPoint": {
      "method": "POST",
      "path": "/test"
    },
    "getConfig": {
      "method": "GET",
      "path": "/config"
    },
    "setConfig": {
      "method": "PUT",
      "path": "/config"
    },
    "resetSubject": {
      "method": "DELETE",
      "path": "/subjects/:id"
    },
    "purgeSubjects": {
      "method": "POST",
      "path": "/subjects/purge"
    }
  },
  "flow": {
    "conditions": [
